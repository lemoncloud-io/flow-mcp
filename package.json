{
  "name": "@lemoncloud/flow-mcp",
  "version": "0.0.0-managed-by-semantic-release",
  "description": "MCP server for Eureka Flow — visual workflow editor",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "flow-mcp": "./dist/stdio.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/stdio.js",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "lint:type": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.14.0",
    "dotenv": "^16.5.0",
    "ws": "^8.20.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/"
  ],
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0"
}
